<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1.5dp"
    app:cardMaxElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="?attr/colorSurfaceVariant">

        <!-- Top Row with Title & Quick Indicators -->
        <TextView
            android:id="@+id/txtNoteTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Note Title Sample"
            android:textColor="?attr/colorOnSurface"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/layoutIndicators"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutIndicators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toTopOf="@id/txtNoteText"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgIndicatorLocked"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="Locked Indicator"
                android:src="@android:drawable/ic_secure"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/imgIndicatorPinned"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="Pinned Indicator"
                android:src="@android:drawable/btn_star_big_on"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/imgIndicatorFavorite"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="Favorite Indicator"
                android:src="@android:drawable/btn_star_big_off"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/imgIndicatorReminder"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="Active alarm set"
                android:src="@android:drawable/ic_lock_idle_alarm"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Body excerpt -->
        <TextView
            android:id="@+id/txtNoteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:text="This is a clean preview excerpt of your active notepad text contents to allow fast summaries without reading entire files."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/txtNoteTitle" />

        <!-- Footer containing Category, Stamp information -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/txtNoteText">

            <TextView
                android:id="@+id/txtNoteCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tag_bg_selected"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:text="Work"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtNoteTagsList"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="#life #ideas"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/txtNoteDate"
                app:layout_constraintStart_toEndOf="@id/txtNoteCategory"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtNoteDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11 Jun"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
